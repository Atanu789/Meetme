# ============================================
# CLERK AUTHENTICATION
# ============================================
# Get these from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ============================================
# JITSI CONFIGURATION
# ============================================
# Self-hosted Jitsi domain with protocol
# 
# Development scenarios:
# - HTTP (local testing): http://meet.melanam.com
# - Auto-detect (uses same protocol as your app): meet.melanam.com
#
# Production scenarios:
# - HTTPS (recommended): https://melanam.com
# - Main domain with HTTPS: https://melanam.com
#
# The component automatically tries both HTTP and HTTPS if one fails
NEXT_PUBLIC_JITSI_DOMAIN=https://melanam.com

# Optional: enable JWT-authenticated private rooms
JITSI_JWT_SECRET=your_jitsi_jwt_secret
JITSI_JWT_ISSUER=melanam

# ============================================
# MONGODB DATABASE
# ============================================
# Local: mongodb://localhost:27017/zoom-clone
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/zoom-clone
MONGODB_URI=mongodb://localhost:27017/zoom-clone


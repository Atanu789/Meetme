# ============================================
# NEXTAUTH EMAIL MAGIC-LINK AUTH
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_strong_random_secret
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ============================================
# JITSI CONFIGURATION
# ============================================
# Self-hosted Jitsi domain with protocol
# 
# Development scenarios:
# - HTTP (local testing): http://meet.melanam.com
# - Auto-detect (uses same protocol as your app): meet.melanam.com
#
# Production scenarios:
# - HTTPS (recommended): https://melanam.com
# - Main domain with HTTPS: https://melanam.com
#
# The component automatically tries both HTTP and HTTPS if one fails
NEXT_PUBLIC_JITSI_DOMAIN=meet.melanam.com

# ============================================
# MEETING AI / LIVE CAPTIONS
# ============================================
# WebSocket endpoint for the realtime caption service
# If you proxy the backend through the same domain, set it to that ws/wss URL.
NEXT_PUBLIC_MEETING_AI_WS_URL=ws://localhost:4010

# Backend service settings
MEETING_AI_PORT=4010
MEETING_AI_HOST=0.0.0.0
MEETING_AI_CORS_ORIGIN=http://localhost:3000

# ============================================
# BOT + ASSEMBLYAI CAPTION PIPELINE
# ============================================
# Required for bot transcription pipeline
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Optional fallback alias
AAI_API_KEY=your_assemblyai_api_key

# Optional override for caption backend target
CAPTION_BACKEND_URL=http://localhost:4010

# Bot tuning
BOT_DISPLAY_NAME=Melanam Note Bot
BOT_CHUNK_SECONDS=20
BOT_CHUNK_SCAN_MS=5000

# Optional: explicit ffmpeg path if ffmpeg is not on PATH
# BOT_FFMPEG_PATH=C:\\ffmpeg\\bin\\ffmpeg.exe

# Linux only: PulseAudio source (sink.monitor)
# BOT_PULSE_SOURCE=g_meet_123456.monitor

# Optional: enable JWT-authenticated private rooms
JITSI_JWT_SECRET=your_jitsi_jwt_secret
JITSI_JWT_ISSUER=melanam

# ============================================
# MONGODB DATABASE
# ============================================
# Local: mongodb://localhost:27017/zoom-clone
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/zoom-clone
MONGODB_URI=mongodb://localhost:27017/zoom-clone

